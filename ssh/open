#!/bin/bash

set -e

PORT="$1"

if [ "$EUID" -ne 0 ]; then
  echo "Please run as root"
  exit 1
fi

if [ -z "$PORT" ]; then
  echo "Usage: ./ssh/open <port>"
  exit 1
fi

case "$PORT" in
  ''|*[!0-9]*)
    echo "Port must be a number"
    exit 1
    ;;
esac

if [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
  echo "Port must be between 1 and 65535"
  exit 1
fi

ufw allow "$PORT/tcp"

echo "Opened $PORT/tcp"
